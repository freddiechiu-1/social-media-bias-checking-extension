{
  "manifest_version": 3,
  "name": "ClaimCheck",
  "version": "0.1.0",
  "description": "Critical-thinking aid for social media posts. Pastes in, exposes patterns, lets you judge.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ClaimCheck"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "host_permissions": [
    "http://localhost:3001/*",
    "http://localhost:9999/*"
  ]
}
